{
  "manifest_version": 3,
  "name": "YouTube Algorithm Inspector",
  "version": "0.1",
  "description": "Locally observe what YouTube remembers about you and generate a short algorithm-awareness report.",
  "permissions": ["storage", "scripting", "tabs", "activeTab"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon48.png"
  },
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
